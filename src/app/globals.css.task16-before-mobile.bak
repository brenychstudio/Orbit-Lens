@import "tailwindcss";

:root {
  --orbit-bg: #030407;
  --orbit-ivory: #f4efe6;
  --orbit-muted: rgba(244, 239, 230, 0.62);
  --orbit-line: rgba(255, 255, 255, 0.14);
  --orbit-glass: rgba(255, 255, 255, 0.075);
}

* {
  box-sizing: border-box;
}

html {
  background: var(--orbit-bg);
  color: var(--orbit-ivory);
}

body {
  min-height: 100vh;
  margin: 0;
  background: var(--orbit-bg);
  color: var(--orbit-ivory);
  font-family:
    Inter,
    ui-sans-serif,
    system-ui,
    -apple-system,
    BlinkMacSystemFont,
    "Segoe UI",
    sans-serif;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  text-rendering: geometricPrecision;
}

button {
  font: inherit;
}

::selection {
  background: rgba(160, 210, 255, 0.22);
  color: var(--orbit-ivory);
}
