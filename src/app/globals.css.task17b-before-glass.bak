@import "tailwindcss";

:root {
  --orbit-bg: #030407;
  --orbit-ivory: #f4efe6;
  --orbit-muted: rgba(244, 239, 230, 0.62);
  --orbit-line: rgba(255, 255, 255, 0.14);
  --orbit-glass: rgba(255, 255, 255, 0.075);
}

* {
  box-sizing: border-box;
}

html {
  background: var(--orbit-bg);
  color: var(--orbit-ivory);
}

body {
  min-height: 100vh;
  margin: 0;
  background: var(--orbit-bg);
  color: var(--orbit-ivory);
  font-family:
    Inter,
    ui-sans-serif,
    system-ui,
    -apple-system,
    BlinkMacSystemFont,
    "Segoe UI",
    sans-serif;
  overflow-x: hidden;
  overscroll-behavior: none;
  -webkit-font-smoothing: antialiased;
  text-rendering: geometricPrecision;
}

button {
  font: inherit;
}

::selection {
  background: rgba(160, 210, 255, 0.22);
  color: var(--orbit-ivory);
}

@media (max-width: 767px) {
  .mobile-stability-mode,
  .mobile-stability-mode * {
    -webkit-backdrop-filter: none !important;
    backdrop-filter: none !important;
  }

  .mobile-stability-mode [style*="blur"] {
    filter: none !important;
  }

  .mobile-stability-mode .mobile-static-layer {
    transform: translateZ(0);
    will-change: transform;
  }
}

.orbit-atmos-noise {
  background-image:
    radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.06) 0 1px, transparent 1px),
    radial-gradient(circle at 70% 60%, rgba(255, 255, 255, 0.035) 0 1px, transparent 1px);
  background-size: 42px 42px, 64px 64px;
  mix-blend-mode: screen;
}

@media (prefers-reduced-motion: reduce) {
  .orbit-atmos-noise {
    opacity: 0.035;
  }
}

@media (max-width: 767px) {
  .orbit-atmos-noise {
    opacity: 0.025;
  }
}
