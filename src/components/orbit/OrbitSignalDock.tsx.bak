"use client";

import { motion } from "motion/react";

type OrbitSignalDockProps = {
  modeId: string;
  accent: string;
};

const dockCopy: Record<
  string,
  {
    signal: string;
    context: string;
    trust: string;
  }
> = {
  vision: {
    signal: "Spatial clarity / city layer",
    context: "Only the next useful signal enters the field of view.",
    trust: "No dashboard. No visual noise.",
  },
  translate: {
    signal: "Live language layer",
    context: "Captions appear as atmosphere, not as a screen.",
    trust: "Face-forward conversation remains intact.",
  },
  recall: {
    signal: "Intentional memory",
    context: "Save a place, a phrase or a moment only when asked.",
    trust: "No silent recording concept.",
  },
  create: {
    signal: "Creator capture field",
    context: "Frame, scout and collect references without leaving the scene.",
    trust: "The interface assists the eye.",
  },
  focus: {
    signal: "Attention quiet mode",
    context:
      "The system removes everything except the signal that matters.",
    trust: "Less interface. More presence.",
  },
  privacy: {
    signal: "Visible trust state",
    context:
      "Capture and memory are always readable, visible and controlled.",
    trust: "Privacy is part of the interface.",
  },
};

export function OrbitSignalDock({ modeId, accent }: OrbitSignalDockProps) {
  const copy = dockCopy[modeId] ?? dockCopy.vision!;

  return (
    <motion.div
      key={modeId}
      initial={{ opacity: 0, y: 8, filter: "blur(8px)" }}
      animate={{ opacity: 1, y: 0, filter: "blur(0px)" }}
      transition={{ duration: 0.56, ease: [0.22, 1, 0.36, 1] }}
      className="mt-4 overflow-hidden rounded-[1.45rem] border border-white/10 bg-black/22 px-4 py-3 shadow-[0_18px_80px_rgba(0,0,0,0.26)] backdrop-blur-xl"
    >
      <div className="grid items-center gap-4 lg:grid-cols-[0.82fr_1.4fr_0.9fr_auto]">
        <div className="flex items-center gap-3">
          <motion.span
            className="h-2.5 w-2.5 rounded-full"
            style={{ background: accent, boxShadow: `0 0 22px ${accent}` }}
            animate={{ opacity: [0.32, 1, 0.32], scale: [0.9, 1.14, 0.9] }}
            transition={{ duration: 3.8, repeat: Infinity, ease: "easeInOut" }}
          />

          <div>
            <p className="text-[0.55rem] uppercase tracking-[0.26em] text-white/30">
              Active Field
            </p>
            <p className="mt-1 text-xs uppercase tracking-[0.2em] text-white/62">
              {copy.signal}
            </p>
          </div>
        </div>

        <div className="relative hidden h-px overflow-hidden bg-white/10 lg:block">
          <motion.div
            className="absolute inset-y-0 left-0 w-1/3"
            style={{
              background: `linear-gradient(90deg, transparent, ${accent}, transparent)`,
            }}
            animate={{ x: ["-120%", "360%"] }}
            transition={{ duration: 5.8, repeat: Infinity, ease: "easeInOut" }}
          />
        </div>

        <div>
          <p className="text-[0.55rem] uppercase tracking-[0.26em] text-white/30">
            Context
          </p>
          <p className="mt-1 text-sm leading-5 text-white/58">{copy.context}</p>
        </div>

        <div className="flex items-center gap-3 lg:justify-end">
          <div className="hidden max-w-[13rem] text-right lg:block">
            <p className="text-[0.55rem] uppercase tracking-[0.26em] text-white/28">
              Trust
            </p>
            <p className="mt-1 text-xs leading-5 text-white/44">{copy.trust}</p>
          </div>

          <button
            type="button"
            className="shrink-0 rounded-full border border-white/14 bg-white/[0.055] px-4 py-2.5 text-[0.58rem] uppercase tracking-[0.24em] text-white/58 transition hover:bg-white/[0.1] hover:text-white"
          >
            Private Preview
          </button>
        </div>
      </div>
    </motion.div>
  );
}
