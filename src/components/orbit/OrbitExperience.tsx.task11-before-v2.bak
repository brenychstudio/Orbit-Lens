"use client";

import { useCallback, useEffect, useMemo, useState } from "react";
import { AnimatePresence, motion } from "motion/react";
import { AtmosphericBackdrop } from "@/components/orbit/AtmosphericBackdrop";
import { ModeInterfaceOverlay } from "@/components/orbit/ModeInterfaceOverlay";
import { ModeVisual } from "@/components/orbit/ModeVisual";
import { OrbitSignalDock } from "@/components/orbit/OrbitSignalDock";
import { ProductOptics } from "@/components/orbit/ProductOptics";
import { ProductHeroReveal } from "@/components/orbit/ProductHeroReveal";
import { ShellChrome } from "@/components/orbit/ShellChrome";
import { SpatialSignalLayer } from "@/components/orbit/SpatialSignalLayer";
import { orbitModes } from "@/data/orbitModes";

export function OrbitExperience() {
  const [activeIndex, setActiveIndex] = useState(0);
  const activeMode = orbitModes[activeIndex] ?? orbitModes[0]!;

  const currentProgress = useMemo(
    () =>
      `${String(activeIndex + 1).padStart(2, "0")} / ${String(orbitModes.length).padStart(2, "0")}`,
    [activeIndex],
  );

  const goToIndex = useCallback((nextIndex: number) => {
    const safeIndex =
      ((nextIndex % orbitModes.length) + orbitModes.length) % orbitModes.length;

    setActiveIndex(safeIndex);
  }, []);

  useEffect(() => {
    function onKeyDown(event: KeyboardEvent) {
      if (event.key === "ArrowRight" || event.key === "ArrowDown") {
        goToIndex(activeIndex + 1);
      }

      if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
        goToIndex(activeIndex - 1);
      }
    }

    window.addEventListener("keydown", onKeyDown);
    return () => window.removeEventListener("keydown", onKeyDown);
  }, [activeIndex, goToIndex]);

  return (
    <main className="relative min-h-screen overflow-hidden bg-[#030407] text-[#f4efe6]">
      <AtmosphericBackdrop accent={activeMode.accent} />
      <ProductHeroReveal accent={activeMode.accent} />

      <section className="relative z-10 flex min-h-screen items-center justify-center px-3 py-4 sm:px-4 md:px-8 md:py-6">
        <div className="mx-auto w-full max-w-[1488px]">
          <motion.div
            className="relative isolate w-full select-none overflow-hidden rounded-[2rem] border border-white/15 bg-white/[0.082] p-3 shadow-[0_52px_180px_rgba(0,0,0,0.78)] backdrop-blur-2xl sm:p-4 md:rounded-[3.2rem] md:p-5 xl:rounded-[3.8rem] xl:p-6 xl:shadow-[0_72px_240px_rgba(0,0,0,0.8)]"
            drag="x"
            dragConstraints={{ left: 0, right: 0 }}
            dragElastic={0.16}
            onDragEnd={(_, info) => {
              if (info.offset.x < -80) goToIndex(activeIndex + 1);
              if (info.offset.x > 80) goToIndex(activeIndex - 1);
            }}
          >
            <ShellChrome accent={activeMode.accent} />

            <div className="mb-3 flex items-center justify-between rounded-full border border-white/10 bg-black/24 px-3 py-2.5 text-[0.56rem] uppercase tracking-[0.22em] text-white/48 sm:px-4 md:mb-4 md:py-3 md:text-[0.66rem] md:tracking-[0.26em]">
              <span>Spatial Shell Interface</span>
              <span>{currentProgress}</span>
            </div>

            <div className="relative overflow-hidden rounded-[1.55rem] border border-white/10 bg-black/28 p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] sm:p-4 md:rounded-[2.3rem] md:p-5 lg:min-h-[590px] xl:rounded-[2.8rem] xl:p-7">
              <div className="absolute inset-0 bg-[radial-gradient(circle_at_54%_0%,rgba(255,255,255,0.16),transparent_42%)]" />
              <div className="absolute inset-0 bg-[linear-gradient(110deg,rgba(255,255,255,0.08),transparent_28%,rgba(255,255,255,0.04)_62%,transparent)]" />

              <div className="relative z-10 grid gap-3 md:gap-4 lg:min-h-[520px] lg:grid-cols-[0.82fr_1.42fr] lg:gap-5">
                <aside className="flex flex-col justify-between overflow-hidden rounded-[1.25rem] border border-white/10 bg-white/[0.045] p-4 backdrop-blur-xl md:rounded-[1.6rem] md:p-6 xl:p-7">
                  <div>
                    <p className="mb-5 text-xs uppercase tracking-[0.34em] text-white/38">
                      Orbit Lens
                    </p>

                    <h1 className="max-w-md text-3xl font-light leading-[0.96] tracking-[-0.07em] text-white sm:text-4xl md:text-5xl">
                      AI placed gently in your field of view.
                    </h1>

                    <p className="mt-5 max-w-sm text-sm leading-6 text-white/54">
                      A fictional AI spatial glasses launch concept where the
                      website behaves like the product interface.
                    </p>

                    <div className="mt-6 flex flex-wrap gap-2">
                      <span className="rounded-full border border-white/12 bg-white/[0.055] px-4 py-2 text-[0.62rem] uppercase tracking-[0.22em] text-white/48">
                        Private Preview
                      </span>
                      <span className="rounded-full border border-white/12 bg-black/24 px-4 py-2 text-[0.62rem] uppercase tracking-[0.22em] text-white/42">
                        Spatial OS Demo
                      </span>
                    </div>
                  </div>

                  <div className="mt-6 md:mt-8">
                    <ProductOptics accent={activeMode.accent} />
                  </div>
                </aside>

                <section className="relative overflow-hidden rounded-[1.25rem] border border-white/10 bg-black/26 p-4 backdrop-blur-xl md:rounded-[1.6rem] md:p-6 xl:p-8">
                  <ModeVisual accent={activeMode.accent} modeId={activeMode.id} />
                  <ModeInterfaceOverlay accent={activeMode.accent} modeId={activeMode.id} />
                  <SpatialSignalLayer accent={activeMode.accent} modeId={activeMode.id} />

                  <AnimatePresence mode="wait">
                    <motion.article
                      key={activeMode.id}
                      initial={{
                        opacity: 0,
                        x: 52,
                        scale: 0.988,
                        filter: "blur(10px)",
                      }}
                      animate={{
                        opacity: 1,
                        x: 0,
                        scale: 1,
                        filter: "blur(0px)",
                      }}
                      exit={{
                        opacity: 0,
                        x: -52,
                        scale: 0.988,
                        filter: "blur(10px)",
                      }}
                      transition={{
                        duration: 0.62,
                        ease: [0.22, 1, 0.36, 1],
                      }}
                      className="relative z-20 flex min-h-[25rem] flex-col justify-between rounded-[1.25rem] sm:min-h-[28rem] lg:min-h-[452px]"
                    >
                      <div>
                        <p
                          className="mb-7 text-xs uppercase tracking-[0.34em]"
                          style={{ color: activeMode.accent }}
                        >
                          {activeMode.eyebrow}
                        </p>

                        <h2 className="max-w-4xl text-[2.65rem] font-light leading-[0.92] tracking-[-0.08em] text-white drop-shadow-[0_8px_34px_rgba(0,0,0,0.82)] sm:text-5xl md:text-6xl xl:text-[5.8rem]">
                          {activeMode.title}
                        </h2>

                        <p className="mt-5 max-w-2xl text-sm leading-6 text-white/68 drop-shadow-[0_6px_22px_rgba(0,0,0,0.86)] sm:text-base md:mt-6 md:leading-7 xl:text-lg">
                          {activeMode.description}
                        </p>
                      </div>

                      <div className="mt-6 grid gap-3 md:grid-cols-[1fr_0.82fr] md:items-end xl:mt-8">
                        <div className="rounded-3xl border border-white/10 bg-white/[0.055] p-5 backdrop-blur-xl">
                          <p className="mb-2 text-xs uppercase tracking-[0.28em] text-white/38">
                            Active Signal
                          </p>
                          <p className="text-sm leading-6 text-white/72">
                            {activeMode.signal}
                          </p>
                        </div>

                        <div className="rounded-3xl border border-white/10 bg-black/28 p-5 backdrop-blur-xl md:text-right">
                          <p className="text-xs uppercase tracking-[0.28em] text-white/38">
                            Tagline
                          </p>
                          <p className="mt-2 text-sm leading-6 text-white/72">
                            {activeMode.tagline}
                          </p>
                        </div>
                      </div>
                    </motion.article>
                  </AnimatePresence>
                </section>
              </div>
            </div>

            <OrbitSignalDock
              accent={activeMode.accent}
              modeId={activeMode.id}
            />

            <div className="mt-3 flex flex-wrap items-center justify-between gap-3 md:mt-4 md:gap-4">
              <div className="flex items-center gap-2 rounded-full border border-white/8 bg-white/[0.03] px-3 py-2">
                {orbitModes.map((mode, index) => (
                  <button
                    key={mode.id}
                    type="button"
                    onClick={() => goToIndex(index)}
                    className="h-2.5 rounded-full border border-white/18 transition-all hover:bg-white/40"
                    style={{
                      width: index === activeIndex ? "2.5rem" : "0.7rem",
                      background:
                        index === activeIndex
                          ? activeMode.accent
                          : "rgba(255,255,255,0.16)",
                    }}
                    aria-label={`Open ${mode.id} mode`}
                  />
                ))}
              </div>

              <div className="flex gap-2">
                <button
                  type="button"
                  onClick={() => goToIndex(activeIndex - 1)}
                  className="rounded-full border border-white/12 bg-white/[0.045] px-4 py-2 text-xs uppercase tracking-[0.22em] text-white/54 transition hover:bg-white/10 hover:text-white"
                >
                  Prev
                </button>
                <button
                  type="button"
                  onClick={() => goToIndex(activeIndex + 1)}
                  className="rounded-full border border-white/12 bg-white/[0.045] px-4 py-2 text-xs uppercase tracking-[0.22em] text-white/54 transition hover:bg-white/10 hover:text-white"
                >
                  Next
                </button>
              </div>
            </div>
          </motion.div>
        </div>
      </section>
    </main>
  );
}
