"use client";

import Image from "next/image";
import { useState } from "react";
import { AnimatePresence, motion } from "motion/react";
import { opticsAssets, type OpticsAsset } from "@/data/opticsAssets";

type OpticsInspectLayerProps = {
  isOpen: boolean;
  accent: string;
  onClose: () => void;
};

const cardPositions: Record<string, string> = {
  floating: "left-[5%] bottom-[18%] w-[16rem] md:w-[20rem] xl:w-[22rem]",
  front: "right-[18%] bottom-[17%] w-[16rem] md:w-[21rem] xl:w-[23rem]",
  side: "left-[35%] top-[9%] w-[20rem] md:w-[27rem] xl:w-[30rem]",
  material: "right-[3%] top-[12%] w-[17rem] md:w-[22rem] xl:w-[24rem]",
  privacy: "left-[34%] bottom-[8%] w-[18rem] md:w-[24rem] xl:w-[27rem]",
};

function InspectCard({
  asset,
  accent,
  selected,
  onSelect,
}: {
  asset: OpticsAsset;
  accent: string;
  selected: boolean;
  onSelect: () => void;
}) {
  const isSquare = asset.ratio === "square";

  return (
    <motion.button
      type="button"
      drag
      dragElastic={0.08}
      dragConstraints={{ left: -280, right: 280, top: -180, bottom: 180 }}
      onClick={onSelect}
      className={`absolute ${cardPositions[asset.id] ?? ""} group overflow-hidden rounded-[1.85rem] border border-white/[0.14] bg-white/[0.052] p-2.5 text-left shadow-[inset_0_1px_0_rgba(255,255,255,0.12),0_34px_140px_rgba(0,0,0,0.44)] backdrop-blur-[28px] md:p-3`}
      initial={{
        opacity: 0,
        y: 18,
        scale: 0.94,
        filter: "blur(18px)",
      }}
      animate={{
        opacity: selected ? 0.28 : 1,
        y: [0, -8, 0],
        scale: selected ? 0.96 : 1,
        filter: "blur(0px)",
      }}
      exit={{
        opacity: 0,
        y: 12,
        scale: 0.94,
        filter: "blur(18px)",
      }}
      transition={{
        opacity: { duration: 0.55, ease: [0.22, 1, 0.36, 1] },
        filter: { duration: 0.55, ease: [0.22, 1, 0.36, 1] },
        scale: { duration: 0.55, ease: [0.22, 1, 0.36, 1] },
        y: { duration: 7.4, repeat: Infinity, ease: "easeInOut" },
      }}
      style={{
        boxShadow: selected
          ? "inset 0 1px 0 rgba(255,255,255,0.1), 0 20px 90px rgba(0,0,0,0.24)"
          : `inset 0 1px 0 rgba(255,255,255,0.1), 0 26px 110px rgba(0,0,0,0.36), 0 0 44px ${accent}22`,
      }}
    >
      <div
        className={`relative overflow-hidden rounded-[1.35rem] border border-white/[0.09] bg-black/30 ${
          isSquare ? "aspect-square" : "aspect-[4/3]"
        }`}
      >
        <Image
          src={asset.src}
          alt={asset.label}
          fill
          sizes="(max-width: 768px) 70vw, 320px"
          className="object-cover transition duration-700 group-hover:scale-[1.035]"
        />

        <div className="absolute inset-0 bg-[radial-gradient(circle_at_50%_22%,rgba(255,255,255,0.14),transparent_42%),linear-gradient(180deg,transparent,rgba(0,0,0,0.54))]" />

        <motion.div
          className="absolute left-4 right-4 top-1/2 h-px"
          style={{
            background: `linear-gradient(90deg, transparent, ${accent}, rgba(255,255,255,0.7), transparent)`,
          }}
          animate={{ opacity: [0.14, 0.52, 0.14], scaleX: [0.9, 1, 0.9] }}
          transition={{ duration: 4.8, repeat: Infinity, ease: "easeInOut" }}
        />
      </div>

      <div className="px-2.5 pb-2.5 pt-3.5">
        <p className="text-[0.58rem] uppercase tracking-[0.28em] text-white/34">
          Optics Layer
        </p>
        <p className="mt-1.5 text-[0.8rem] uppercase tracking-[0.2em] text-white/74">
          {asset.label}
        </p>
      </div>
    </motion.button>
  );
}

function ExpandedAsset({
  asset,
  accent,
  onClose,
}: {
  asset: OpticsAsset;
  accent: string;
  onClose: () => void;
}) {
  return (
    <motion.div
      className="absolute left-1/2 top-1/2 z-40 w-[min(86vw,72rem)] -translate-x-1/2 -translate-y-1/2 overflow-hidden rounded-[2.35rem] border border-white/[0.15] bg-white/[0.06] p-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.13),0_52px_210px_rgba(0,0,0,0.66)] backdrop-blur-[30px]"
      initial={{ opacity: 0, scale: 0.92, filter: "blur(18px)" }}
      animate={{ opacity: 1, scale: 1, filter: "blur(0px)" }}
      exit={{ opacity: 0, scale: 0.94, filter: "blur(18px)" }}
      transition={{ duration: 0.62, ease: [0.22, 1, 0.36, 1] }}
    >
      <div className="relative aspect-[16/9] overflow-hidden rounded-[1.45rem] border border-white/[0.09] bg-black/40">
        <Image
          src={asset.src}
          alt={asset.label}
          fill
          sizes="80vw"
          className="object-cover"
          priority
        />

        <div className="absolute inset-0 bg-[radial-gradient(circle_at_50%_18%,rgba(255,255,255,0.1),transparent_36%),linear-gradient(180deg,rgba(0,0,0,0.05),rgba(0,0,0,0.55))]" />

        <motion.div
          className="absolute left-10 right-10 top-1/2 h-px"
          style={{
            background: `linear-gradient(90deg, transparent, ${accent}, rgba(255,255,255,0.9), ${accent}, transparent)`,
          }}
          animate={{ opacity: [0.18, 0.72, 0.18], scaleX: [0.92, 1, 0.92] }}
          transition={{ duration: 4.8, repeat: Infinity, ease: "easeInOut" }}
        />
      </div>

      <div className="flex flex-col gap-4 px-2 py-4 md:flex-row md:items-center md:justify-between">
        <div>
          <p className="text-[0.58rem] uppercase tracking-[0.28em] text-white/34">
            Product Inspection
          </p>
          <h3 className="mt-1 text-2xl font-light tracking-[-0.055em] text-white md:text-3xl">
            {asset.label}
          </h3>
          <p className="mt-2 max-w-xl text-sm leading-6 text-white/58">
            {asset.caption}
          </p>
        </div>

        <button
          type="button"
          onClick={onClose}
          className="rounded-full border border-white/[0.14] bg-white/[0.06] px-5 py-3 text-[0.6rem] uppercase tracking-[0.24em] text-white/62 transition hover:bg-white/[0.1] hover:text-white"
        >
          Collapse
        </button>
      </div>
    </motion.div>
  );
}

export function OpticsInspectLayer({
  isOpen,
  accent,
  onClose,
}: OpticsInspectLayerProps) {
  const [selectedId, setSelectedId] = useState<string | null>(null);
  const selectedAsset =
    opticsAssets.find((asset) => asset.id === selectedId) ?? null;

  const handleClose = () => {
    setSelectedId(null);
    onClose();
  };

  return (
    <AnimatePresence>
      {isOpen ? (
        <motion.div
          className="absolute inset-0 z-50 origin-center overflow-hidden rounded-[1.55rem] bg-black/[0.24] backdrop-blur-[4px] md:rounded-[2.3rem] xl:rounded-[2.8rem]"
          initial={{
            opacity: 0,
            scale: 0.72,
            y: 22,
            filter: "blur(24px)",
            clipPath: "inset(18% 22% 18% 22% round 2.4rem)",
          }}
          animate={{
            opacity: 1,
            scale: 1,
            y: 0,
            filter: "blur(0px)",
            clipPath: "inset(0% 0% 0% 0% round 2.4rem)",
          }}
          exit={{
            opacity: 0,
            scale: 0.78,
            y: 18,
            filter: "blur(22px)",
            clipPath: "inset(16% 20% 16% 20% round 2.4rem)",
          }}
          transition={{
            duration: 0.92,
            ease: [0.22, 1, 0.36, 1],
          }}
        >
          <div className="absolute inset-0 bg-[radial-gradient(circle_at_50%_42%,rgba(255,255,255,0.08),transparent_34%),linear-gradient(90deg,rgba(0,0,0,0.54),rgba(0,0,0,0.18),rgba(0,0,0,0.54))]" />

          <motion.div
            className="absolute left-8 right-8 top-8 h-px"
            style={{
              background: `linear-gradient(90deg, transparent, ${accent}, rgba(255,255,255,0.58), ${accent}, transparent)`,
            }}
            initial={{ scaleX: 0.22, opacity: 0 }}
            animate={{ scaleX: 1, opacity: [0.2, 0.54, 0.2] }}
            exit={{ scaleX: 0.22, opacity: 0 }}
            transition={{ duration: 0.9, ease: [0.22, 1, 0.36, 1] }}
          />

          <motion.div
            className="absolute bottom-8 left-8 right-8 h-px"
            style={{
              background: `linear-gradient(90deg, transparent, rgba(255,255,255,0.36), ${accent}, rgba(255,255,255,0.36), transparent)`,
            }}
            initial={{ scaleX: 0.22, opacity: 0 }}
            animate={{ scaleX: 1, opacity: [0.16, 0.42, 0.16] }}
            exit={{ scaleX: 0.22, opacity: 0 }}
            transition={{ duration: 1, ease: [0.22, 1, 0.36, 1] }}
          />

          <motion.div
            className="absolute bottom-8 top-8 left-8 w-px"
            style={{
              background: `linear-gradient(180deg, transparent, ${accent}, transparent)`,
            }}
            initial={{ scaleY: 0.18, opacity: 0 }}
            animate={{ scaleY: 1, opacity: [0.1, 0.32, 0.1] }}
            exit={{ scaleY: 0.18, opacity: 0 }}
            transition={{ duration: 1.05, ease: [0.22, 1, 0.36, 1] }}
          />

          <motion.div
            className="absolute bottom-8 top-8 right-8 w-px"
            style={{
              background: `linear-gradient(180deg, transparent, rgba(255,255,255,0.32), ${accent}, transparent)`,
            }}
            initial={{ scaleY: 0.18, opacity: 0 }}
            animate={{ scaleY: 1, opacity: [0.08, 0.26, 0.08] }}
            exit={{ scaleY: 0.18, opacity: 0 }}
            transition={{ duration: 1.05, ease: [0.22, 1, 0.36, 1] }}
          />

          <motion.div
            className="absolute left-1/2 top-[48%] h-[48rem] w-[80rem] -translate-x-1/2 -translate-y-1/2 rounded-full blur-3xl"
            style={{
              background: `radial-gradient(circle, ${accent} 0%, rgba(255,255,255,0.08) 18%, transparent 62%)`,
            }}
            animate={{ opacity: [0.1, 0.22, 0.1], scale: [0.96, 1.04, 0.96] }}
            transition={{ duration: 8, repeat: Infinity, ease: "easeInOut" }}
          />

          <div className="absolute left-5 top-5 z-30 max-w-[25rem] md:left-8 md:top-8">
            <p
              className="text-[0.6rem] uppercase tracking-[0.34em]"
              style={{ color: accent }}
            >
              Optics Inspect Mode
            </p>
            <h2 className="mt-3 max-w-[24rem] text-3xl font-light leading-[0.92] tracking-[-0.075em] text-white drop-shadow-[0_12px_42px_rgba(0,0,0,0.86)] md:text-5xl">
              Product layers suspended in the field.
            </h2>
            <p className="mt-4 max-w-sm text-xs leading-5 text-white/50 md:text-sm md:leading-6">
              Drag the optical cards. Select one to inspect. Return to field when the product layer closes.
            </p>
          </div>

          <button
            type="button"
            onClick={handleClose}
            className="absolute right-5 top-5 z-50 rounded-full border border-white/[0.14] bg-white/[0.06] px-5 py-3 text-[0.58rem] uppercase tracking-[0.24em] text-white/62 shadow-[0_20px_80px_rgba(0,0,0,0.34)] backdrop-blur-[18px] transition hover:bg-white/[0.1] hover:text-white md:right-8 md:top-8"
          >
            Return to Field
          </button>

          <div className="absolute inset-0 z-20">
            {opticsAssets.map((asset) => (
              <InspectCard
                key={asset.id}
                asset={asset}
                accent={accent}
                selected={selectedId === asset.id}
                onSelect={() => setSelectedId(asset.id)}
              />
            ))}
          </div>

          <AnimatePresence>
            {selectedAsset ? (
              <ExpandedAsset
                key={selectedAsset.id}
                asset={selectedAsset}
                accent={accent}
                onClose={() => setSelectedId(null)}
              />
            ) : null}
          </AnimatePresence>

          <div className="absolute bottom-5 left-1/2 z-30 -translate-x-1/2 rounded-full border border-white/[0.12] bg-white/[0.055] px-6 py-3 text-[0.58rem] uppercase tracking-[0.28em] text-white/44 shadow-[0_18px_70px_rgba(0,0,0,0.28)] backdrop-blur-[20px]">
            Drag / Select / Inspect
          </div>
        </motion.div>
      ) : null}
    </AnimatePresence>
  );
}
