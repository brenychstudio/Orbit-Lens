"use client";

import { AnimatePresence, motion } from "motion/react";

type ModeInteractiveOverlayProps = {
  modeId: string;
  accent: string;
  isVisible?: boolean;
};

const traceRows = [
  "Manual memory request",
  "Place context recognized",
  "Voice fragment indexed",
  "No silent recording state",
];

function RecallMemoryOverlay({ accent }: { accent: string }) {
  return (
    <motion.div
      className="pointer-events-none absolute inset-0 z-[14] hidden overflow-hidden md:block"
      initial={{ opacity: 0, filter: "blur(14px)" }}
      animate={{ opacity: 1, filter: "blur(0px)" }}
      exit={{ opacity: 0, filter: "blur(14px)" }}
      transition={{ duration: 0.72, ease: [0.22, 1, 0.36, 1] }}
    >
      <motion.div
        className="absolute left-[31%] top-[19%] h-[18rem] w-[31rem] rounded-[1.6rem] border border-white/[0.12] bg-white/[0.035] shadow-[inset_0_1px_0_rgba(255,255,255,0.08),0_30px_120px_rgba(0,0,0,0.34)] backdrop-blur-[18px]"
        animate={{
          y: [0, -8, 0],
          opacity: [0.42, 0.72, 0.42],
        }}
        transition={{ duration: 7.4, repeat: Infinity, ease: "easeInOut" }}
      >
        <div className="absolute left-6 right-6 top-6">
          <div className="flex items-center justify-between">
            <div className="flex items-center gap-2">
              <motion.span
                className="h-2 w-2 rounded-full"
                style={{ background: accent, boxShadow: `0 0 18px ${accent}` }}
                animate={{ opacity: [0.3, 1, 0.3], scale: [0.9, 1.2, 0.9] }}
                transition={{ duration: 2.8, repeat: Infinity, ease: "easeInOut" }}
              />
              <p className="text-[0.52rem] uppercase tracking-[0.3em] text-white/38">
                Recall trace
              </p>
            </div>

            <p className="text-[0.5rem] uppercase tracking-[0.28em] text-white/28">
              User initiated
            </p>
          </div>

          <div className="mt-7 space-y-4">
            {traceRows.map((row, index) => (
              <div key={row} className="flex items-center gap-4">
                <span className="w-28 text-[0.52rem] uppercase tracking-[0.24em] text-white/32">
                  {String(index + 1).padStart(2, "0")}
                </span>

                <div className="relative h-px flex-1 bg-white/[0.08]">
                  <motion.div
                    className="absolute inset-y-0 left-0"
                    style={{
                      background: `linear-gradient(90deg, ${accent}, rgba(255,255,255,0.56), transparent)`,
                    }}
                    animate={{ width: ["8%", "72%", "18%"], opacity: [0.16, 0.56, 0.16] }}
                    transition={{
                      duration: 4.4 + index * 0.45,
                      repeat: Infinity,
                      ease: "easeInOut",
                      delay: index * 0.35,
                    }}
                  />
                </div>

                <span className="w-44 text-[0.56rem] uppercase tracking-[0.18em] text-white/44">
                  {row}
                </span>
              </div>
            ))}
          </div>
        </div>
      </motion.div>

      <motion.div
        className="absolute right-[17%] top-[34%] h-[10.5rem] w-[10.5rem] rounded-full border border-white/[0.09] bg-white/[0.025] backdrop-blur-[12px]"
        style={{ boxShadow: `0 0 70px ${accent}18` }}
        animate={{
          opacity: [0.22, 0.5, 0.22],
          scale: [0.96, 1.06, 0.96],
        }}
        transition={{ duration: 6.8, repeat: Infinity, ease: "easeInOut" }}
      >
        <div className="absolute inset-8 rounded-full border border-white/[0.08]" />
        <div className="absolute inset-[3.6rem] rounded-full border border-white/[0.12]" />
        <motion.span
          className="absolute left-1/2 top-1/2 h-2 w-2 -translate-x-1/2 -translate-y-1/2 rounded-full"
          style={{ background: accent, boxShadow: `0 0 24px ${accent}` }}
          animate={{ opacity: [0.35, 1, 0.35], scale: [0.9, 1.25, 0.9] }}
          transition={{ duration: 3, repeat: Infinity, ease: "easeInOut" }}
        />
      </motion.div>

      <motion.div
        className="absolute bottom-[22%] left-[44%] h-[4.8rem] w-[19rem] rounded-full border border-white/[0.1] bg-white/[0.035] shadow-[inset_0_1px_0_rgba(255,255,255,0.07),0_24px_90px_rgba(0,0,0,0.28)] backdrop-blur-[16px]"
        animate={{
          y: [0, 6, 0],
          opacity: [0.34, 0.62, 0.34],
        }}
        transition={{ duration: 6.2, repeat: Infinity, ease: "easeInOut" }}
      >
        <div className="absolute inset-x-6 top-1/2 h-px -translate-y-1/2 bg-white/[0.09]" />

        <motion.div
          className="absolute top-1/2 h-[0.24rem] w-20 -translate-y-1/2 rounded-full blur-[1px]"
          style={{
            background: `linear-gradient(90deg, transparent, ${accent}, rgba(255,255,255,0.76), transparent)`,
            boxShadow: `0 0 22px ${accent}`,
          }}
          animate={{ left: ["10%", "62%", "10%"] }}
          transition={{ duration: 5.8, repeat: Infinity, ease: "easeInOut" }}
        />

        <div className="absolute left-7 top-1/2 h-2 w-2 -translate-y-1/2 rounded-full bg-white/22" />
        <div className="absolute left-1/2 top-1/2 h-2.5 w-2.5 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white/30" />
        <div className="absolute right-7 top-1/2 h-2 w-2 -translate-y-1/2 rounded-full bg-white/22" />
      </motion.div>

      <motion.div
        className="absolute left-[18%] right-[16%] top-[50%] h-px"
        style={{
          background: `linear-gradient(90deg, transparent, ${accent}, rgba(255,255,255,0.46), ${accent}, transparent)`,
        }}
        animate={{
          opacity: [0.08, 0.32, 0.08],
          scaleX: [0.92, 1, 0.92],
        }}
        transition={{ duration: 5.4, repeat: Infinity, ease: "easeInOut" }}
      />

      <motion.div
        className="absolute right-[23%] bottom-[27%] rounded-full border border-white/[0.09] bg-black/22 px-4 py-2 text-[0.54rem] uppercase tracking-[0.26em] text-white/38 backdrop-blur-[14px]"
        animate={{ opacity: [0.2, 0.52, 0.2], y: [4, -4, 4] }}
        transition={{ duration: 5.6, repeat: Infinity, ease: "easeInOut" }}
      >
        Memory density / calm
      </motion.div>
    </motion.div>
  );
}

export function ModeInteractiveOverlay({
  modeId,
  accent,
  isVisible = true,
}: ModeInteractiveOverlayProps) {
  return (
    <AnimatePresence mode="wait">
      {isVisible && modeId === "recall" ? (
        <RecallMemoryOverlay key="recall-memory-overlay" accent={accent} />
      ) : null}
    </AnimatePresence>
  );
}
